# Copy to .env and fill in values
# cp .env.example .env

# --- Environment ---
ENVIRONMENT=development
DEBUG=true

# --- Database ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=woundos
DB_PASSWORD=woundos_dev
DB_NAME=woundos
# For Cloud SQL (production only):
# DB_INSTANCE_CONNECTION_NAME=project:region:instance

# --- Google Cloud Storage ---
# Leave empty for local filesystem storage in development
GCS_BUCKET=woundos-scans-dev
GCS_PROJECT_ID=

# --- Google Pub/Sub ---
# Leave empty for background task processing in development
PUBSUB_PROJECT_ID=
PUBSUB_TOPIC_SCAN_READY=scan-ready

# --- Firebase Auth ---
# Leave empty for dev stub auth (accepts any token)
FIREBASE_PROJECT_ID=

# --- Anthropic (Claude Haiku for clinical summaries) ---
# Get your key from https://console.anthropic.com
ANTHROPIC_API_KEY=

# --- JWT ---
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_SECONDS=3600
